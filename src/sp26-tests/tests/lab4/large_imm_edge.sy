// Input: None
// Output: -781120

int main() {

    int i = 2000, a, b, c, d;
    int h[2048];

    a = i + 2047;
    b = i - 2048;
    c = i + 2048;
    d = i - 2049;

    i = i * 2;
    h[i - 2048] = 2047;
    h[i - 2049] = 2048;

    write((a + c) * (b + d) + h[i - 2048] + h[i + (-2049)]);
    return 0;

}