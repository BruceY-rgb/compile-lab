// 主函数
int main() {
    int n;
    int m;
    int i;
    int j;
    int u;
    int v;
    int w;
    int graph[100];
    int idx;

    n = read();
    m = read();

    initGraph(n, graph);

    i = 0;
    while (i < m) {
        u = read();
        v = read();
        w = read();
        idx = u * 10 + v;
        graph[idx] = w;
        i = i + 1;
    }

    floydWarshall(n, graph);

    i = 0;
    while (i < n) {
        j = 0;
        while (j < n) {
            idx = i * 10 + j;
            write(graph[idx]);
            j = j + 1;
        }
        i = i + 1;
    }

    return 0;
}
